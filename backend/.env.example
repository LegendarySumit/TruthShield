# Copy this file to .env and fill in your actual values
# NEVER commit the .env file — it is listed in .gitignore

# Runtime environment: development | production
ENVIRONMENT=development
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODELS=gemini-2.5-flash,gemini-2.0-flash,gemini-2.5-flash-lite,gemini-3-flash-preview

# --- Security and network hardening ---
FORCE_HTTPS=false
# List values can be comma-separated or JSON array.
# Example CSV: TRUSTED_HOSTS=localhost,127.0.0.1
# Example JSON: TRUSTED_HOSTS=["localhost","127.0.0.1"]
TRUSTED_HOSTS=localhost,127.0.0.1
SECURITY_CSP=default-src 'self'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self' https:; frame-ancestors 'none'; base-uri 'self'; form-action 'self'

# --- CORS ---
# In production, set explicit origins like: https://yourdomain.com
CORS_ALLOW_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
CORS_ALLOW_CREDENTIALS=false
CORS_DEV_ALLOW_ALL=true

# --- Request and text limits ---
MAX_REQUEST_BODY_BYTES=100000
MIN_TEXT_CHARS=50
MAX_TEXT_CHARS=20000
CACHE_MAX_ITEMS=200
CACHE_TTL_SECONDS=900
MODEL_VERSION=v3

# --- Observability ---
METRICS_ENABLED=true
SENTRY_DSN=
ALERT_LATENCY_MS=1500
ALERT_5XX_PER_MINUTE=20

# --- Predict endpoint abuse protection ---
PREDICT_WINDOW_SECONDS=60
PREDICT_GLOBAL_LIMIT=120
PREDICT_PER_IP_LIMIT=20
PREDICT_BURST_WINDOW_SECONDS=10
PREDICT_BURST_LIMIT=8
PREDICT_BLOCK_SECONDS=300

# --- Optional CAPTCHA protection (Turnstile) ---
CAPTCHA_ENABLED=false
CAPTCHA_PROVIDER=turnstile
CAPTCHA_SECRET_KEY=
CAPTCHA_VERIFY_URL=https://challenges.cloudflare.com/turnstile/v0/siteverify
CAPTCHA_TIMEOUT_SECONDS=5

# --- Gemini resilience controls ---
GEMINI_TIMEOUT_SECONDS=12
GEMINI_MAX_RETRIES=2
GEMINI_RETRY_JITTER_MS=250
GEMINI_CIRCUIT_FAIL_THRESHOLD=5
GEMINI_CIRCUIT_OPEN_SECONDS=60
